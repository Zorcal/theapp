{
  "swagger": "2.0",
  "info": {
    "title": "theapp Auth API",
    "version": "v1"
  },
  "tags": [
    {
      "name": "AuthService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/auth/magic-link": {
      "post": {
        "summary": "RequestMagicLink sends a sign-in link to the given email address.\nIf no account exists for the address, one is created automatically.\nAlways returns success to avoid leaking whether the address is registered.",
        "operationId": "AuthService_RequestMagicLink",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "description": "Request message for RequestMagicLink.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1RequestMagicLinkRequest"
            }
          },
          {
            "name": "x-idempotency-key",
            "description": "A client-generated UUID. Retrying the same request with the same key returns the original result instead of sending a second sign-in email.",
            "in": "header",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "AuthService"
        ],
        "security": []
      }
    },
    "/v1/auth/refresh": {
      "post": {
        "summary": "RefreshAccessToken rotates the refresh token and issues a new token pair.\nThe supplied refresh token is revoked upon success.",
        "operationId": "AuthService_RefreshAccessToken",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1TokenPair"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "description": "Request message for RefreshAccessToken.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1RefreshAccessTokenRequest"
            }
          }
        ],
        "tags": [
          "AuthService"
        ],
        "security": []
      }
    },
    "/v1/auth/revoke": {
      "post": {
        "summary": "RevokeRefreshToken invalidates a refresh token, ending the session.",
        "operationId": "AuthService_RevokeRefreshToken",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "description": "Request message for RevokeRefreshToken.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1RevokeRefreshTokenRequest"
            }
          }
        ],
        "tags": [
          "AuthService"
        ],
        "security": []
      }
    },
    "/v1/auth/sessions/revoke-all": {
      "post": {
        "summary": "RevokeAllSessions revokes all active refresh tokens for the authenticated user, ending all sessions.\nRequires a valid access token.",
        "operationId": "AuthService_RevokeAllSessions",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {}
            }
          }
        ],
        "tags": [
          "AuthService"
        ]
      }
    },
    "/v1/auth/verify": {
      "post": {
        "summary": "VerifyMagicLink exchanges a magic-link token for an access/refresh token pair.",
        "operationId": "AuthService_VerifyMagicLink",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1TokenPair"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "description": "Request message for VerifyMagicLink.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1VerifyMagicLinkRequest"
            }
          }
        ],
        "tags": [
          "AuthService"
        ],
        "security": []
      }
    }
  },
  "definitions": {
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1RefreshAccessTokenRequest": {
      "type": "object",
      "properties": {
        "refreshToken": {
          "type": "string",
          "description": "The refresh token issued by a previous VerifyMagicLink or RefreshAccessToken call."
        }
      },
      "description": "Request message for RefreshAccessToken."
    },
    "v1RequestMagicLinkRequest": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Email address to send the sign-in link to."
        }
      },
      "description": "Request message for RequestMagicLink."
    },
    "v1RevokeRefreshTokenRequest": {
      "type": "object",
      "properties": {
        "refreshToken": {
          "type": "string",
          "description": "The refresh token to revoke."
        }
      },
      "description": "Request message for RevokeRefreshToken."
    },
    "v1TokenPair": {
      "type": "object",
      "properties": {
        "accessToken": {
          "type": "string",
          "description": "JWT bearer token. Include as: Authorization: Bearer \u003caccess_token\u003e."
        },
        "refreshToken": {
          "type": "string",
          "description": "Opaque refresh token. Use with RefreshAccessToken to obtain a new pair."
        },
        "expiresIn": {
          "type": "string",
          "format": "int64",
          "description": "Remaining lifetime of access_token in seconds."
        }
      },
      "description": "TokenPair holds a short-lived JWT access token and a long-lived refresh token."
    },
    "v1VerifyMagicLinkRequest": {
      "type": "object",
      "properties": {
        "token": {
          "type": "string",
          "description": "The token from the magic-link URL query parameter."
        }
      },
      "description": "Request message for VerifyMagicLink."
    }
  },
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "description": "Access token from VerifyMagicLink or RefreshAccessToken. Format: 'Bearer {token}'",
      "name": "Authorization",
      "in": "header"
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
