{
  "swagger": "2.0",
  "info": {
    "title": "theapp User API",
    "version": "v1"
  },
  "tags": [
    {
      "name": "UserService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/users": {
      "get": {
        "summary": "Lists users, optionally filtered and paginated.",
        "operationId": "UserService_ListUsers",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListUsersResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "description": "Maximum number of users to return.",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageToken",
            "description": "Token for fetching the next page of results.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "orderBy",
            "description": "Field to order the results by, e.g., \"create_time\" or \"update_time\".",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter.email",
            "description": "Match users whose email starts with this prefix.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter.name",
            "description": "Match users whose name starts with this prefix.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "UserService"
        ]
      },
      "post": {
        "summary": "Creates a new user.",
        "operationId": "UserService_CreateUser",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1User"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "description": "Request message for creating a user.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1CreateUserRequest"
            }
          }
        ],
        "tags": [
          "UserService"
        ]
      }
    },
    "/v1/users/{id}": {
      "get": {
        "summary": "Gets a user by ID.",
        "operationId": "UserService_GetUser",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1User"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "description": "The ID of the user to retrieve.",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "UserService"
        ]
      }
    },
    "/v1/users/{user.id}": {
      "patch": {
        "summary": "Updates a user.",
        "operationId": "UserService_UpdateUser",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1User"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "user.id",
            "description": "Unique identifier for the user. Output only.",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UserServiceUpdateUserBody"
            }
          }
        ],
        "tags": [
          "UserService"
        ]
      }
    }
  },
  "definitions": {
    "UserServiceUpdateUserBody": {
      "type": "object",
      "properties": {
        "user": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string",
              "description": "Email address of the user."
            },
            "createTime": {
              "type": "string",
              "format": "date-time",
              "description": "Timestamp when the user was created. Output only.",
              "readOnly": true
            },
            "updateTime": {
              "type": "string",
              "format": "date-time",
              "description": "Timestamp when the user was last updated. Output only.",
              "readOnly": true
            },
            "name": {
              "type": "string",
              "description": "Name of the user (first and last name)."
            },
            "etag": {
              "type": "string",
              "description": "The ETag for the current version of the user. Helps to prevent\nsimultaneous updates of a user from overwriting each other (\"mid-air\ncollisions\").\n\nIf this is provided on update, it must match the server's ETag.",
              "readOnly": true
            }
          },
          "description": "The user to update. The user's `id` identifies which user to update.",
          "title": "The user to update. The user's `id` identifies which user to update."
        },
        "updateMask": {
          "type": "string",
          "description": "The list of fields to update. When omitted, all populated fields are updated."
        }
      },
      "description": "Request message for updating a user.",
      "required": [
        "user"
      ]
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1CreateUserRequest": {
      "type": "object",
      "properties": {
        "user": {
          "$ref": "#/definitions/v1User",
          "description": "The user to create."
        }
      },
      "description": "Request message for creating a user.",
      "required": [
        "user"
      ]
    },
    "v1ListUsersResponse": {
      "type": "object",
      "properties": {
        "users": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1User"
          },
          "description": "List of users returned in the response."
        },
        "totalSize": {
          "type": "integer",
          "format": "int32",
          "description": "Total number of users in the system."
        },
        "nextPageToken": {
          "type": "string",
          "description": "Token for fetching the next page of results, if applicable."
        }
      },
      "description": "Response message for listing users."
    },
    "v1User": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user. Output only.",
          "readOnly": true
        },
        "email": {
          "type": "string",
          "description": "Email address of the user."
        },
        "createTime": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user was created. Output only.",
          "readOnly": true
        },
        "updateTime": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user was last updated. Output only.",
          "readOnly": true
        },
        "name": {
          "type": "string",
          "description": "Name of the user (first and last name)."
        },
        "etag": {
          "type": "string",
          "description": "The ETag for the current version of the user. Helps to prevent\nsimultaneous updates of a user from overwriting each other (\"mid-air\ncollisions\").\n\nIf this is provided on update, it must match the server's ETag.",
          "readOnly": true
        }
      },
      "description": "User represents a user in the system."
    },
    "v1UserFilter": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Match users whose email starts with this prefix."
        },
        "name": {
          "type": "string",
          "description": "Match users whose name starts with this prefix."
        }
      },
      "description": "UserFilter specifies criteria for filtering users in a ListUsers request.\nThis is a typed filter — a deliberate deviation from AIP-160 to avoid the\ncomplexity of a free-form filter parser; see schemas/README.md.\nAll fields are optional; omitted fields match all users."
    }
  },
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "description": "Access token from VerifyMagicLink or RefreshAccessToken. Format: 'Bearer {token}'",
      "name": "Authorization",
      "in": "header"
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
